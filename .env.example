# Hype-Fear Alert System — copy to .env and fill in
# Rotate keys at the URLs below.

# Required
XAI_API_KEY=                # https://console.x.ai
TELEGRAM_BOT_TOKEN=         # https://t.me/BotFather → /newbot
TELEGRAM_CHAT_ID=           # https://t.me/userinfobot → /start

# Recommended
POLYGON_API_KEY=            # https://polygon.io/dashboard — unlocks options flow in backtest

# Optional
NEWSAPI_KEY=                # https://newsapi.org/account — extra news source

# Tuning (defaults shown)
SCAN_INTERVAL_SECS=300
ALERT_COOLDOWN_SECS=3600
HYPE_THRESHOLD=0.45
FEAR_THRESHOLD=-0.45
CONFIDENCE_MIN=0.40
PRICE_CACHE_TTL=240
STATE_DIR=./state
